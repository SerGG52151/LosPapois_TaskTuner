{
    "name": "todolistapp-react",
    "version": "0.1.0",
    "private": true,
    "dependencies": {
        "@emotion/react": "^11.9.0",
        "@emotion/styled": "^11.8.1",
        "@mui/icons-material": "^5.8.0",
        "@mui/material": "^5.8.0",
        "@mui/styles": "^5.7.0",
        "autoprefixer": "^10.4.27",
        "moment": "^2.29.3",
        "postcss": "^8.5.9",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-moment": "^1.1.2",
        "react-router-dom": "^6.30.3",
        "react-scripts": "5.0.0",
        "typescript": "^4.6.4"
    },
    "scripts": {
        "tw:build": "tailwindcss -i ./src/tailwind-input.css -o ./src/tailwind.css --minify",
