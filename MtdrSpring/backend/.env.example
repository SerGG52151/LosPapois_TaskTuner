# Copy to .env and fill in real values. Do NOT commit .env.
# Keys intentionally lowercase to match OracleConfiguration.java and the Docker/K8s env vars.

# Oracle ATP datasource
db_url=jdbc:oracle:thin:@<db_alias>?TNS_ADMIN=<absolute_path_to_wallet>
db_user=admin
dbpassword=change_me
driver_class_name=oracle.jdbc.OracleDriver

# Telegram bot
telegram.bot.token=your_bot_token
telegram.bot.name=your_bot_name

# DeepSeek (optional)
deepseek.enabled=false
deepseek.api.key=sk-test
deepseek.api.url=https://api.deepseek.com/v1/chat/completions
